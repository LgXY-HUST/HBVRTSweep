X11 SOFT_TURNOFF SOFT_TURNOFFD ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY =2E-9
E1 VCC2 H_PMOS_GATE VALUE={V(HGATE_DIG)*V(H_PMOS_VGS)* IF(V(SOFT_TURNOFF) >0.5,0,1) }
E3 L_NMOS_GATE VEE2 VALUE={(1-V(HGATE_DIG))*V(L_NMOS_VGS)*IF(V(SOFT_TURNOFF) >0.5,0,1) }
R1 VCC2 TOUTA 1E12
R2 VEE2 TOUTA 1E12
EA1 NOD1 GND2 VALUE={IF( V(SOFT_TURNOFF) > 0.5, 5.95,V(TOUTA,GND2)) }
RA1 NOD1 NOD2 1
CA1 NOD2 GND2 85N
EA2 NOD3 GND2 VALUE={IF( V(SOFT_TURNOFF) > 0.5 & V(SAFE_OFF_PLT) > 0.5, V(VEE2,GND2),V(TOUTA,GND2)) }
RA2 NOD3 NOD4 1
CA2 NOD4 GND2 10N

G_DW TOUTA VEE2 VALUE={IF( V(SOFT_TURNOFF) >0.5 & V(SAFE_OFF_PLT) <0.5, 1,0) * TABLE(V(TOUTA,NOD2),0,0,500M,12.5)}
G_DW2 TOUTA VEE2 VALUE={IF( V(SOFT_TURNOFF) >0.5 & V(SAFE_OFF_PLT) >0.5, 1,0) * TABLE(V(TOUTA,NOD4),0,0, 500M,12.5) }
RCB1 VCC2 TOUTA 1E12
RCB2 TOUTA VEE2 1E12
M_H_PMOS TOUTA H_PMOS_GATE VCC2 VCC2 ONE_EDI3031AS_H_PMOS
M_L_NMOS TOUTA L_NMOS_GATE VEE2 VEE2 ONE_EDI3031AS_L_NMOS
