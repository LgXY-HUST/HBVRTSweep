X16 DATA VCC1 ONE_EDI3031AS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X17 NRST VCC1 ONE_EDI3031AS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X170 ASC VCC2 ONE_EDI3031AS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X18 GND2 AIP ONE_EDI3031AS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X19 AIP VCC2 ONE_EDI3031AS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
X20 GND2 DESAT ONE_EDI3031AS_ESD_DIO PARAMS: P_V_BV=0.3 P_I_BV=1M
