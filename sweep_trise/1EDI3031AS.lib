R_2 RDY_CTRL_DIG RDY_CTRL_DIG_DEL 1
C_2 RDY_CTRL_DIG_DEL 0 1N
R_3 NFLT_CTRL_DIG NFLT_CTRL_DIG_DEL 1
C_3 NFLT_CTRL_DIG_DEL 0 1N
G_RDY RDY GND1 VALUE={V(RDY,GND1)/20*IF(V(RDY_CTRL_DIG_DEL) >0.5,1,0)*IF(V(VCC1,GND1)< 2,0,1)}
G_NFLT NFLT GND1 VALUE={V(NFLT,GND1)/20*IF(V(NFLT_CTRL_DIG_DEL) >0.5,1,0)*IF(V(VCC1,GND1)< 2,0,1)}
.MODEL ONE_EDI3031AS_SW VSWITCH (VON=0.9 VOFF=0.1 RON=20 ROFF=1MEG)
