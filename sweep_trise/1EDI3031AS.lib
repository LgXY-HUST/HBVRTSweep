.MODEL ONE_EDI3031AS_L_NMOS NMOS (LEVEL=1 VTO=1 CGSO=150N W=10M L=1U RB=1M RG=10 RD=10M TT=10N LAMBDA=0.001 KP=241U )
.MODEL ONE_EDI3031AS_SAFE_PMOS PMOS (LEVEL=1 VTO=-1 CGSO=1N W=10M L=1U RB=1M RG=10 RD=10M TT=10N LAMBDA=0.001 KP=190U )
.MODEL ONE_EDI3031AS_SAFE_NMOS NMOS (LEVEL=1 VTO=1 CGSO=1N W=10M L=1U RB=1M RG=10 RD=10M TT=10N LAMBDA=0.001 KP=190U )
