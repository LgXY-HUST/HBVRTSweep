.SUBCKT 1EDI3031AS VCC1 GND1 INP INN NFLT NRST EN RDY DATA GND2 VEE2 VCC2 TOUT CLAMP_GATE DESAT OCPP OCPN ASC
RX CLAMP_GATE GND2 1E12
CGATE CLAMP_GATE GND2 1P
R1 TOUT GND2 1E12
C2 TOUT GND2 1P
G_CLAMP CLAMP_GATE VEE2 VALUE={(V(CLAMP_GATE,VEE2)/10)*IF(V(VCC2,GND2) < 2,1,0)}
G_RDY RDY GND1 VALUE={(V(RDY,GND1)/1K)*IF(V(VCC1,GND1) < 2,1,0)}
R_NFLT NFLT GND1 1E12
C_NFLT NFLT GND1 1P
R_RDY RDY GND1 1E12
C_RDY RDY GND1 1P
R_VCC1 VCC1 GND1 1E12
C_VCC1 VCC1 GND1 1P
R_VCC2 VCC2 GND2 1E12
C_VCC2 VCC2 GND2 1P
