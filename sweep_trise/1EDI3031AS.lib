.SUBCKT ONE_EDI3031AS_DATA_LOGIC VCC1 VCC2 AIP GND2 DATA GND1
+NFLT_OCP_CTRL_DIG NFLT_DESAT_CTRL_DIG RDY_PS_CTRL_DIG RDY_OSM_CTRL_DIG RDY_GM_CTRL_DIG RDY_OCPOPEN_CTRL_DIG
+UVLO1 UVLO2 OVLO2 VCC1_UV VCC2_UV VCC2_OV NFLT_DIG RDY_DIG MODE EN_DD Q1_VCC1UV Q2_VCC2UV VCC2LOW_UV_LPF
E1 PRIM_READY 0 VALUE={IF(V(Q1_VCC1UV) >0.5, 1, 0)}
E1000 RESERVED 0 VALUE={0}
E2 OSM_ERROR 0 VALUE={V(RDY_OSM_CTRL_DIG)}
E4 GATEMON_ERROR 0 VALUE={V(RDY_GM_CTRL_DIG)}
E5 DESAT_ERROR 0 VALUE={V(NFLT_DESAT_CTRL_DIG)}
E6 OCP_ERROR 0 VALUE={IF(V(NFLT_OCP_CTRL_DIG) >0.5 | V(RDY_OCPOPEN_CTRL_DIG) > 0.5, 1, 0)}
E7 UVLO2_ERROR 0 VALUE={IF(V(UVLO2) > 0.5,1,0)}
E8 OVLO2_ERROR 0 VALUE={IF(V(OVLO2) > 0.5,1,0)}
E9 SEC_READY 0 VALUE={IF(V(Q2_VCC2UV) > 0.5 & V(VCC2LOW_UV_LPF) < 0.5, 0, 1)}
E10 DIAG 0 VALUE={V(PRIM_READY)*(2**0)+V(PRIM_READY)*(2**1)+V(PRIM_READY)*(2**2)+V(PRIM_READY)*(2**3)+V(RESERVED)*(2**4)+V(
+ OSM_ERROR)*(2**5)+V(GATEMON_ERROR)*(2**6)+V(DESAT_ERROR)*(2**7)+
+V(OCP_ERROR)*(2**8)+V(UVLO2_ERROR)*(2**9)+V(OVLO2_ERROR)*(2**10)+V(SEC_READY)*(2**11)}
E101 DUTY_CYCLE_DIAG 0 VALUE={V(DIAG)/4096}
C_DC DC 0 25U
E1100 DUTY_CYCLE_IN 0 VALUE={V(DUTY_CYCLE_DIAG)}
XDFF_1 CLOCK DUTY_CYCLE_IN DUTY_CYCLE ONE_EDI3031AS_SAMPLING_CIRCUIT
E12 I1 0 VALUE={1/(4*LIMIT(V(DUTY_CYCLE),0.0037,0.995))}
E13 I2 0 VALUE={1/(4*(1-LIMIT(V(DUTY_CYCLE),0.0037,0.995)))}
G_UP 0 DC VALUE={(1-V(CLOCK))*V(I2)*IF(TIME<1N,0,1)*TABLE( (1-V(DC)),0,0,10M,1) }
G_DW DC 0 VALUE={V(I1)*IF(TIME<1N,0,1)*TABLE(V(DC),0,0,10M,1)*V(CLOCK)}
R1 DC 0 1E12
X1 CLOCK1 CLOCK ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY=1E-9
X2 DC CLOCK1 0 ONE_EDI3031AS_STP_IDEAL PARAMS: P_TH_UP=0.999 P_TH_DW=0.001
