E19 SET9 0 VALUE={IF( ((V(MODE) > 1.5 & V(MODE) < 2.5) | V(ASC_DIG) > 0.5) & V(FLOAT_DD) > 0.5,1,0)}
E20 RESET9 0 VALUE={IF( ((V(MODE) < 1.5 | V(MODE) > 2.5) & V(ASC_DIG) < 0.5) | V(FLOAT_DD) < 0.5 | V(ASC_DIG_ERASE) > 0.5 ,1,0)}
X2 SET7 RESET7 SOFT_TURNOFF_ANALOG SOFT_TURNOFFN ONE_EDI3031AS_RS_LATCH
X3 SET8 RESET8 NORMAL_TURNOFFA NORMAL_TURNOFFN ONE_EDI3031AS_RS_LATCH
X4 SET9 RESET9 FLOAT_OUT FLOAT_OUTN ONE_EDI3031AS_RS_LATCH
X5 SOFT_TURNOFF_ANALOG SOFT_TURNOFF ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY=3E-9
R_1 NORMAL_TURNOFFA NORMAL_TURNOFF 10
