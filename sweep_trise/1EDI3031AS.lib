.SUBCKT ONE_EDI3031AS_TIMING_FILTER_ON IN OUT TIME PARAMS: OFF_DELAY=1E-12
X1 IN IN_DIG_DEL ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY={OFF_DELAY}
R1 IN 0 1E9
R2 OUT 0 1E9
G_RISE IN IN_DEL VALUE={V(IN,IN_DEL)/ MAX((V(TIME)/ABS(LOG(0.001))/1E-9),0.1)}
C_RISE IN_DEL 0 1N
R_3 IN_DEL 0 1E12
GA IN_DEL 0 VALUE={V(IN_DEL,0)/1M* IF( V(IN_DIG_DEL) < 0.5,1,0)}
X_CMP IN_DEL OUT 0 ONE_EDI3031AS_STP_IDEAL PARAMS: P_TH_UP=0.999 P_TH_DW=0.001
.ENDS ONE_EDI3031AS_TIMING_FILTER_ON
.SUBCKT ONE_EDI3031AS_DFF_2 PREB CLRB CLK D Q QN PARAMS: P_C_DELAY=3E-9
R_Q Q 0 1E12
R_QN QN 0 1E12
R1 D 0 1E9
R2 CLK 0 1E9
R3 CLRB 0 1E9
R4 PREB 0 1E9
X1 CLK CLK_DEL ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY={P_C_DELAY}
E_Q Q 0 VALUE={ IF( V(PREB) <0.5 & V(CLRB) > 0.5 , 1,IF( V(PREB) > 0.5 &
+V(CLRB) > 0.5 & V(CLK,CLK_DEL)>0.1 & V(D) > 0.5 ,1, IF(V(QN) > 0.5 ,0,1))) }
E_QN QN 0 VALUE={IF( (V(PREB) > 0.5 & V(CLRB) < 0.5 ) | TIME <1NS,1 , IF(V(PREB) > 0.5 & V(CLRB) > 0.5
+& V(CLK,CLK_DEL) > 0.1 & V(D) < 0.5 , 1, IF( V(Q) > 0.5 , 0, 1))) }
.ENDS ONE_EDI3031AS_DFF_2
.SUBCKT ONE_EDI3031AS_OUTPUT_STAGE GND2 VCC2 TOUT VEE2 IN_DD EN_DD NORMAL_TURNOFF SOFT_TURNOFF FLOAT_OUT ASC_DIG MODE
X1 SOFT_TURNOFF SAFE_OFF_PLT ONE_EDI3031AS_ADV_FILTER2 PARAMS: P_C_DELAY = 9.409713774570457E-08
E1000 SAFE_OFF_PLT_DUM 0 VALUE={V(SAFE_OFF_PLT)}
X2 SAFE_OFF_PLT_DUM PLT_TO_OFF ONE_EDI3031AS_ADV_FILTER2 PARAMS: P_C_DELAY =7.238241365054197E-09
E100 HGATE_DIGA 0 VALUE={IF(V(ASC_DIG) > 0.5,1,IF( V(IN_DD) > 0.5 & V(EN_DD) > 0.5 & V(NORMAL_TURNOFF) < 0.5,1,0))}
R_11 HGATE_DIGA HGATE_DIG 10
