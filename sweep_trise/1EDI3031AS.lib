X27 OCPN GND2 ONE_EDI3031AS_CL_DIO PARAMS: P_V_BV=2.8 P_I_BV=1M
X28 GND2 OCPP ONE_EDI3031AS_CL_DIO PARAMS: P_V_BV=2.8 P_I_BV=1M
X29 GND2 OCPN ONE_EDI3031AS_CL_DIO PARAMS: P_V_BV=2.8 P_I_BV=1M
X_GD_TEMPLATE VCC1 GND1 INP INN NFLT NRST EN RDY DATA GND2 VEE2 VCC2 TOUT CLAMP_GATE DESAT OCPP OCPN ASC ONE_EDI3031AS_GD_TEMPLATE
.ENDS 1EDI3031AS
.SUBCKT ONE_EDI3031AS_GD_TEMPLATE VCC1 GND1 INP INN NFLT NRST EN RDY DATA GND2 VEE2 VCC2 TOUT GATE DESAT OCPP OCPN ASC PARAMS:
G_VCC1 VCC1 GND1 VALUE={IF(V(MODE) > 2.5 & V(MODE) < 3.5, 5MA, IF(V(MODE) > 3.5 & V(IN_DD) >0.5,10M, IF(V(MODE) >3.5 & V(IN_DD) 
+ <0.5, 5.5M,0))) }
G_VCC2 VCC2 GND2 VALUE={IF(V(MODE) > 3.5 & V(IN_DD) >0.5,9.52M, IF(V(MODE) >3.5 & V(IN_DD) <0.5, 9.52M,0)) }
G_VEE2 VEE2 GND2 VALUE={IF(V(MODE) > 3.5,1.5M,0) }
XINPUT VCC1 INP INN EN GND1 IN_DD EN_DD INPUT_CTRL ONE_EDI3031AS_INPUT_STAGE
XDESAT VCC2 GND2 TOUT_MAX_DIG DESAT INPUT_CTRL NFLT_DESAT_DIG DESAT2OFF_DIG GATE_VEE_DIG TOUT_MIN_DIG MODE ASC_DIG 
+ ONE_EDI3031AS_DESAT_STAGE
XGM VCC2 VEE2 GND2 TOUT GATE GM_DD GM_DIG_Q1 RDY_GM_DIG TOUT_MAX_DIG INPUT_CTRL GATE_VEE_DIG TOUT_MIN_DIG MODE GATE_VEE_DIG_LPF 
+ ASC_DIG SOFT_TURNOFF ONE_EDI3031AS_GM
XOSM VCC2 VEE2 GND2 TOUT IVCC2 IVEE2 FLOAT_DIG FLOAT_DD RDY_OSM_DIG INPUT_CTRL MODE ASC_DIG GM_DD OCP2OFF DESAT2OFF_DIG 
+ SOFT_TURNOFF ONE_EDI3031AS_OSM
XMILLER VCC2 GATE VEE2 GND2 INPUT_CTRL ASC_DIG ONE_EDI3031AS_ACTIVE_MILLER_CLAMP
XOCP OCPP OCPN VCC2 VEE2 GND2 OCP_NORMAL_TURNOFF OCP2OFF NFLT_OCP_DIG TOUT INPUT_CTRL NFLT_DIG RDY_DIG RDY_OCP_OPEN_DIG 
+ OCP_OPEN_DIG GATE_VEE_DIG_LPF ONE_EDI3031AS_OCP
XSUPPLY VCC1 GND1 VCC2 GND2 UVLO1 UVLO2 OVLO2 RDY_PS_DIG VCC1_UV VCC2_UV VCC2_OV Q1_VCC1UV Q2_VCC2UV VCC2LOW_UV_LPF 
+ ONE_EDI3031AS_SUPPLY_MONITORING
XREADY UVLO1 UVLO2 OVLO2 FLOAT_DIG GM_DIG_Q1 OCP_OPEN_DIG DEV_READY Q1_VCC1UV Q2_VCC2UV ONE_EDI3031AS_DEVICE_READY
XLOGIC NRST NFLT RDY VCC1 GND1 DEV_READY RDY_PS_DIG RDY_OSM_DIG RDY_GM_DIG RDY_OCP_OPEN_DIG NFLT_DESAT_DIG NFLT_OCP_DIG 
+ OCP_NORMAL_TURNOFF OCP2OFF IN_DD EN_DD DESAT2OFF_DIG GM_DD FLOAT_DD UVLO1 UVLO2 OVLO2 NRST_DIG NORMAL_TURNOFF SOFT_TURNOFF 
+ FLOAT_OUT NFLT_DIG RDY_DIG MODE TOUT_MIN_DIG NFLT_OCP_CTRL_DIG NFLT_DESAT_CTRL_DIG RDY_PS_CTRL_DIG RDY_OSM_CTRL_DIG RDY_GM_CTRL_DIG 
+ RDY_OCPOPEN_CTRL_DIG Q1_VCC1UV Q2_VCC2UV ASC_DIG ONE_EDI3031AS_LOGIC_STAGE
XOUTPUT GND2 VCC2 TOUT VEE2 IN_DD EN_DD NORMAL_TURNOFF SOFT_TURNOFF FLOAT_OUT ASC_DIG MODE ONE_EDI3031AS_OUTPUT_STAGE
XDIAGRAM UVLO1 NRST_DIG DEV_READY DESAT2OFF_DIG OCP2OFF EN_DD MODE VCC2LOW_UV_LPF ASC_DIG ONE_EDI3031AS_DIAGRAM
XDATA_LOGIC VCC1 VCC2 AIP GND2 DATA GND1 NFLT_OCP_CTRL_DIG NFLT_DESAT_CTRL_DIG RDY_PS_CTRL_DIG RDY_OSM_CTRL_DIG RDY_GM_CTRL_DIG 
+ RDY_OCPOPEN_CTRL_DIG UVLO1 UVLO2 OVLO2 VCC1_UV VCC2_UV VCC2_OV NFLT_DIG RDY_DIG MODE EN_DD Q1_VCC1UV Q2_VCC2UV VCC2LOW_UV_LPF 
+ ONE_EDI3031AS_DATA_LOGIC
XASC_BLOCK VCC2 ASC GND2 ASC_DIG ONE_EDI3031AS_ASC_BLOCK
.ENDS ONE_EDI3031AS_GD_TEMPLATE
.SUBCKT ONE_EDI3031AS_INPUT_STAGE VCC1 INP INN EN GND1 IN_DD EN_DD INPUT_CTRL PARAMS:
+ P_EN_MIN_PW=1E-9 P_EN_DELAY=1E-09 P_EN_TH_UP=2.1 P_EN_TH_DW=1.1
+P_IN_MIN_PW=1E-9 P_C_TPD=1.9E-09 P_TH_TPD=0.5 P_TH_HIN_OFF=0.9 P_TH_LIN_OFF=0.9 P_TH_HIN_ON=2.1 P_TH_LIN_ON=2.1
G1 INP GND1 VALUE={MAX(0.3U, V(INP,GND1)/48K)}
G2 EN GND1 VALUE={MAX(0.3U, V(EN,GND1)/48K)}
G5 VCC1 INN VALUE={MAX(4U, V(VCC1,INN)/52K)}
X1 EN EN_DIG GND1 ONE_EDI3031AS_STP_IDEAL PARAMS: P_TH_UP = 2.1 P_TH_DW = 0.6
X2 EN_DIG EN_LPF_DIG ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY = 1.4476482730108394E-09
X3 EN_LPF_DIG EN_DD ONE_EDI3031AS_RC_DELAY_BASE PARAMS: P_C_DELAY = 5.4285714285714293E-08
X4A INP INP_DIG GND1 ONE_EDI3031AS_STP_IDEAL PARAMS: P_TH_UP=2.1 P_TH_DW=0.6
X4B INN INN_DIG GND1 ONE_EDI3031AS_STP_IDEAL PARAMS: P_TH_UP=2.1 P_TH_DW=0.6
X4C INN_DIG INN_DD ONE_EDI3031AS_RC_DELAY_10 PARAMS: P_C_DELAY = 2.0000000000000004E-08
E1 IN_DIG 0 VALUE= {IF( V(INP_DIG) > 0.5 & V(INN_DD) < 0.5, 1, 0)}
X5 IN_DIG IN_LPF_DIG ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY = 1.4476482730108394E-09
X6 IN_LPF_DIG IN_DD ONE_EDI3031AS_RC_DELAY_BASE PARAMS: P_C_DELAY = 5.4285714285714293E-08
E2 INPUT_CTRL 0 VALUE={V(IN_LPF_DIG)*V(EN_LPF_DIG)}
.ENDS ONE_EDI3031AS_INPUT_STAGE
.SUBCKT ONE_EDI3031AS_RS_LATCH S1 R1 Q QN
R1 S1 0 1E9
R2 R1 0 1E9
R_Q Q 0 1E9
R_QN QN 0 1E9
X1 S1 S ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY=1.5E-10
X2 R1 R ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY=2.5E-10
E_Q Q 0 VALUE={ IF( V(S) > 0.5 & V(R) < 0.5,1, IF( (V(R) > 0.5 ) | TIME < 1NS, 0, IF(V(QN)>0.5,0,1)))}
E_QN QN 0 VALUE={ IF( V(R) > 0.5 ,1, IF( (V(R) < 0.5 & V(S) > 0.5), 0, IF(V(Q)>0.5,0,1))) }
.ENDS ONE_EDI3031AS_RS_LATCH
.SUBCKT ONE_EDI3031AS_DESAT_STAGE VCC2 GND2 TOUT_MAX_DIG DESAT IN_DD NFLT_DESAT_DIG DESAT2OFF_DIG GATE_VEE_DIG TOUT_MIN_DIG MODE 
+ ASC_DIG
R_1 DESAT GND2 1E12
C_1 DESAT GND2 1P
G1 VCC2 DESAT VALUE={500U*TABLE(V(VCC2,DESAT),0,0,500M,1)*TABLE(V(VCC2,GND2),0,0,1,0,2,1)}
X1 DESAT DESAT_DIG GND2 ONE_EDI3031AS_STP_IDEAL PARAMS: P_TH_UP= 6 P_TH_DW= 5.99
X12 DESAT_DIG DESAT_DIG_LPF ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY = 3.6915030961776404E-08
E01 SET 0 VALUE={IF( (V(DESAT_DIG_LPF) > 0.5 & V(IN_DD) > 0.5 & V(TOUT_MAX_DIG) > 0.5 & V(MODE) > 2.5) | ( V(ASC_DIG) > 0.5 & V(
+ DESAT_DIG_LPF) > 0.5) ,1,0)}
E02 RESET 0 VALUE={1-V(TOUT_MIN_DIG)}
X01 SET RESET Q1 Q1N ONE_EDI3031AS_RS_LATCH
X101 GATE_VEE_DIG GATE_VEE_DIG_LPF ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY = 4.632474473634686E-08
E_DESATCL DESATCL 0 VALUE={IF( V(GATE_VEE_DIG_LPF) > 0.5 & (V(IN_DD) > 0.5 | V(ASC_DIG) > 0.5) & V(TOUT_MIN_DIG) > 0.5 , 0, 1) }
X13 Q1 DESAT2OFF_DIG ONE_EDI3031AS_RC_DELAY_10 PARAMS: P_C_DELAY = 1E-10
X14 Q1 NFLT_DESAT_DIG ONE_EDI3031AS_RC_DELAY_10 PARAMS: P_C_DELAY = 1.7142857142857143E-07
G2 DESAT GND2 VALUE={V(DESAT,GND2)/40 * IF( V(Q1) >0.5 | V(DESATCL) > 0.5, 1,0)}
.ENDS ONE_EDI3031AS_DESAT_STAGE
.SUBCKT ONE_EDI3031AS_GM VCC2 VEE2 GND2 TOUT GATE GM_DD GM_DIG_Q1 RDY_GM_DIG TOUT_MAX_DIG IN_DD GATE_VEE_DIG TOUT_MIN_DIG MODE 
+ GATE_VEE_DIG_LPF ASC_DIG SOFT_TURNOFF
E1 GATEVCCH 0 VALUE={V(VCC2, GND2) -2.1}
E2 GATEVCCL 0 VALUE={V(VCC2, GND2) -3}
E3 GATEVEEH 0 VALUE={V(VEE2, GND2) +3}
E4 GATEVEEL 0 VALUE={V(VEE2, GND2) +2.1}
X100 GATE GATE_VCC_DIG GND2 GATEVCCH GATEVCCL ONE_EDI3031AS_STP_IDEAL1
X101 GATE GATE_VEE_DIG GND2 GATEVEEH GATEVEEL ONE_EDI3031AS_STP_IDEAL1
X102 TOUT TOUT_MAX_DIG GND2 GATEVCCH GATEVCCL ONE_EDI3031AS_STP_IDEAL1
X103 TOUT TOUT_MIN_DIG GND2 GATEVEEH GATEVEEL ONE_EDI3031AS_STP_IDEAL1
X104 GATE_VCC_DIG GATE_VCC_DIG_LPF ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY = 4.632474473634686E-08
X105 GATE_VEE_DIG GATE_VEE_DIG_LPF ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY = 4.632474473634686E-08
X106 TOUT_MAX_DIG TOUT_MAX_DIG_LPF ONE_EDI3031AS_ADV_FILTER PARAMS: P_C_DELAY = 4.632474473634686E-08
E5 SET1 0 VALUE={IF( (V(IN_DD) >0.5 & V(GATE_VCC_DIG_LPF) <0.5 & V(MODE) > 2.5) | ( V(ASC_DIG) > 0.5 & V(GATE_VCC_DIG_LPF) <0.5 & V(
+ SOFT_TURNOFF) < 0.5),1,0)}
E6 RESET1 0 VALUE={IF( (V(IN_DD) < 0.5 & V(ASC_DIG) < 0.5) | (V(GATE_VCC_DIG) > 0.5 & (V(IN_DD) > 0.5 | V(ASC_DIG) > 0.5)) | (V(
+ ASC_DIG) > 0.5 & V(RESET) > 0.5)
+| (V(ASC_DIG) < 0.5 & V(RDY_GM_DIG) > 0.5) ,1,0)}
X10 SET1 RESET1 Q1 Q1N ONE_EDI3031AS_RS_LATCH
ETIMP3 TIMP3 0 VALUE={3.6U}
X1 Q1 Q1_LPF TIMP3 ONE_EDI3031AS_TIMING_FILTER_ON
E7 SET2 0 VALUE={IF( V(IN_DD) < 0.5 & V(ASC_DIG) < 0.5 & V(GATE_VEE_DIG_LPF) > 0.5 & V(MODE) > 2.5,1,0)}
E8 RESET2 0 VALUE={IF( V(IN_DD) > 0.5 | V(ASC_DIG) > 0.5 | (V(GATE_VEE_DIG) < 0.5 & V(IN_DD) < 0.5 & V(ASC_DIG) <0.5) | (V(ASC_DIG) 
+ > 0.5 & V(RESET) > 0.5)
+| (V(ASC_DIG) < 0.5 & V(RDY_GM_DIG) > 0.5) ,1,0)}
